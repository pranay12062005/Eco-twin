datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String?
  googleId     String?        @unique
  name         String
  title        String         @default("Eco Enthusiast")
  avatar       String?
  ecoScore     Int            @default(50)
  accent       String         @default("green")
  notifications Boolean       @default(true)
  closet       ClothingItem[]
  badges       UserBadge[]
  scanHistory  ScanHistory[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ClothingItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  brand     String?
  material  String?
  origin    String?
  ecoScore  Int
  carbonKg  Float
  verdict   String
  category  String
  color     String?
  price     Float?
  wears     Int      @default(0)
  tags      String[]
  imageUrl  String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String
  name       String
  icon       String
  desc       String   @default("")
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model ScanHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String
  result    Json
  verdict   String
  saved     Boolean  @default(false)
  createdAt DateTime @default(now())
}
